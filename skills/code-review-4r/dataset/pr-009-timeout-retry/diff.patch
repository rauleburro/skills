+++ b/test/test_profile.py
@@ -0,0 +1,10 @@
+from unittest import mock
+from src.profile import fetch_profile
+
+
+def test_fetch_profile_passes_timeout():
+    with mock.patch("src.profile._session") as s:
+        s.return_value.get.return_value.json.return_value = {"id": "u1"}
+        assert fetch_profile("u1") == {"id": "u1"}
+        _, kwargs = s.return_value.get.call_args
+        assert kwargs["timeout"] == 5
