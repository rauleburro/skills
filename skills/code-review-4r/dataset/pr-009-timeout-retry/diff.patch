@@ -0,0 +1,18 @@
+import requests
+from requests.adapters import HTTPAdapter
+from urllib3.util.retry import Retry
+
+REQUEST_TIMEOUT_S = 5
+
+
+def _session():
+    s = requests.Session()
+    s.mount("https://", HTTPAdapter(max_retries=Retry(total=3, backoff_factor=0.5)))
+    return s
+
+
+def fetch_profile(uid):
+    """Fetch a user profile with a bounded timeout and retry/backoff."""
+    resp = _session().get(f"https://api.example.com/users/{uid}", timeout=REQUEST_TIMEOUT_S)
+    resp.raise_for_status()
+    return resp.json()
diff --git a/test/test_profile.py b/test/test_profile.py
