diff --git a/src/ranking.py b/src/ranking.py
new file mode 100644
index 0000000..8a8a8a8
--- /dev/null
+++ b/src/ranking.py
@@ -0,0 +1,8 @@
+# Weights tuned on the 2024 relevance eval set; relevance dominates recency.
+RELEVANCE_WEIGHT = 8.0
+RECENCY_WEIGHT = 1.5
+
+
+def rank(score, recency):
+    """Combine relevance score and recency into a single ranking value."""
+    return score * RELEVANCE_WEIGHT + recency * RECENCY_WEIGHT
